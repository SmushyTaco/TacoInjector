<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TacoInjector.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="TacoInjector"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#171A21}">

    <Grid Padding="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#171A21}">
        <Border
            Padding="22"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#171A21}"
            Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2A2F3A}"
            StrokeThickness="1">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="10">

                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="3">
                        <VerticalStackLayout.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnWindowDragPanUpdated" />
                        </VerticalStackLayout.GestureRecognizers>

                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Image
                                Source="taco_color_256.png"
                                WidthRequest="28"
                                HeightRequest="28"
                                VerticalOptions="Center" />
                            <Label
                                Text="TacoInjector"
                                FontSize="23"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                        </HorizontalStackLayout>
                        <Label
                            Text="Select a DLL, choose a target process, then inject."
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Column="1"
                                           Spacing="6"
                                           VerticalOptions="Start">
                        <Button
                            Text="−"
                            WidthRequest="30"
                            HeightRequest="30"
                            Padding="0"
                            CornerRadius="15"
                            FontSize="16"
                            BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#232A36}"
                            TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                            Clicked="OnMinimizeClicked" />

                        <Button
                            Text="×"
                            WidthRequest="30"
                            HeightRequest="30"
                            Padding="0"
                            CornerRadius="15"
                            FontSize="16"
                            BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#3A2026}"
                            TextColor="{AppThemeBinding Light=#991B1B, Dark=#FCA5A5}"
                            Clicked="OnExitClicked" />
                    </HorizontalStackLayout>
                </Grid>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="6">
                    <Label
                        Text="Target process"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                    <Entry
                        x:Name="ProcessNameEntry"
                        Grid.Row="1"
                        HeightRequest="40"
                        Text="minecraft.windows.exe"
                        ClearButtonVisibility="WhileEditing" />
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <CheckBox
                            x:Name="CustomTargetCheckBox"
                            CheckedChanged="OnCustomTargetChanged" />
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label
                                Text="Custom target"
                                FontAttributes="Bold"
                                FontSize="13"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                            <Label
                                Text="Edit process name."
                                FontSize="11"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout x:Name="AutoInjectArea" Grid.Column="1" Spacing="8" Opacity="0.45">
                        <CheckBox
                            x:Name="AutoInjectCheckBox"
                            IsEnabled="False"
                            CheckedChanged="OnAutoInjectChanged" />
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label
                                Text="Auto inject"
                                FontAttributes="Bold"
                                FontSize="13"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                            <Label
                                Text="Retry automatically."
                                FontSize="11"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Grid>

                <Grid Grid.Row="3"
                      ColumnDefinitions="*,86"
                      ColumnSpacing="10">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="6">
                        <Label
                            Text="DLL path"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                        <Entry
                            x:Name="DllPathEntry"
                            Grid.Row="1"
                            HeightRequest="40"
                            Text="Click &quot;Select DLL&quot; to select the dll file"
                            TextChanged="OnDllPathChanged"
                            ClearButtonVisibility="WhileEditing" />
                    </Grid>

                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="6">
                        <Label
                            Text="Delay"
                            FontSize="12"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                        <Entry
                            x:Name="DelayEntry"
                            Grid.Row="1"
                            HeightRequest="40"
                            Text="5"
                            Keyboard="Numeric"
                            HorizontalTextAlignment="Center" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="4"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">

                    <Border
                        x:Name="SelectButton"
                        HeightRequest="44"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light=#F3F0FF, Dark=#222A3A}"
                        Stroke="{AppThemeBinding Light=#DDD6FE, Dark=#364156}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Opacity="0.20" Radius="10" Offset="0,2" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSelectClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="8"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <Border
                                WidthRequest="28"
                                HeightRequest="28"
                                BackgroundColor="{AppThemeBinding Light=#E9D5FF, Dark=#2E3650}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Grid WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Path
                                        Data="M5,2 L13,2 L18,7 L18,18 L5,18 Z"
                                        Stroke="{AppThemeBinding Light=#5B21B6, Dark=#EDE9FE}"
                                        StrokeThickness="1.6"
                                        Fill="Transparent" />
                                    <Path
                                        Data="M13,2 L13,7 L18,7"
                                        Stroke="{AppThemeBinding Light=#5B21B6, Dark=#EDE9FE}"
                                        StrokeThickness="1.6"
                                        Fill="Transparent" />
                                    <Path
                                        Data="M8,11 L15,11 M8,14 L13,14"
                                        Stroke="{AppThemeBinding Light=#5B21B6, Dark=#EDE9FE}"
                                        StrokeThickness="1.4"
                                        Fill="Transparent" />
                                </Grid>
                            </Border>
                            <Label
                                Grid.Column="1"
                                Text="Select DLL"
                                FontSize="13"
                                FontAttributes="Bold"
                                VerticalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#312E81, Dark=#EDE9FE}" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="InjectButton"
                        Grid.Column="1"
                        HeightRequest="44"
                        IsEnabled="False"
                        Opacity="0.45"
                        Padding="14,0"
                        BackgroundColor="#A78BFA"
                        Stroke="#BBA7FF"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Opacity="0.25" Radius="12" Offset="0,3" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInjectClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="8"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <Border
                                WidthRequest="24"
                                HeightRequest="24"
                                BackgroundColor="#C4B5FD"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label
                                    Text="⚡"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center" />
                            </Border>
                            <Label
                                Grid.Column="1"
                                Text="Inject"
                                FontSize="13"
                                FontAttributes="Bold"
                                VerticalTextAlignment="Center"
                                TextColor="#221843" />
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        HeightRequest="44"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#202838}"
                        Stroke="{AppThemeBinding Light=#D8B4FE, Dark=#334155}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Opacity="0.20" Radius="10" Offset="0,2" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHideClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="8"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <Border
                                WidthRequest="28"
                                HeightRequest="28"
                                BackgroundColor="{AppThemeBinding Light=#E0E7FF, Dark=#2A3448}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Grid WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Path
                                        Data="M2.5,10 C4.4,6.8 7.0,5 10,5 C13.0,5 15.6,6.8 17.5,10 C16.7,11.4 15.7,12.5 14.5,13.3 M12.2,14.5 C11.5,14.8 10.8,15 10,15 C7.0,15 4.4,13.2 2.5,10"
                                        Stroke="{AppThemeBinding Light=#4338CA, Dark=#C4B5FD}"
                                        StrokeThickness="1.6"
                                        StrokeLineCap="Round"
                                        StrokeLineJoin="Round"
                                        Fill="Transparent" />
                                    <Path
                                        Data="M7.8,7.8 C8.4,7.3 9.1,7 10,7 C11.7,7 13,8.3 13,10 C13,10.9 12.7,11.6 12.2,12.2 M10.8,12.9 C10.5,13 10.3,13 10,13 C8.3,13 7,11.7 7,10 C7,9.7 7,9.5 7.1,9.2"
                                        Stroke="{AppThemeBinding Light=#4338CA, Dark=#C4B5FD}"
                                        StrokeThickness="1.5"
                                        StrokeLineCap="Round"
                                        StrokeLineJoin="Round"
                                        Fill="Transparent" />
                                    <Path
                                        Data="M4,4 L16,16"
                                        Stroke="{AppThemeBinding Light=#4338CA, Dark=#C4B5FD}"
                                        StrokeThickness="1.9"
                                        StrokeLineCap="Round"
                                        Fill="Transparent" />
                                </Grid>
                            </Border>
                            <Label
                                Grid.Column="1"
                                Text="Hide"
                                FontSize="13"
                                FontAttributes="Bold"
                                VerticalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#312E81, Dark=#EDE9FE}" />
                        </Grid>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="5"
                    Padding="10,6"
                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#263041}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Label
                        x:Name="StatusLabel"
                        Text="Ready  •  v1.0"
                        FontSize="12"
                        LineBreakMode="TailTruncation"
                        TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
